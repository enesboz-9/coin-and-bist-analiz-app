    teknik_skor  = teknik_sonuc.get("skor", 50)
    temel_skor   = temel_sonuc.get("temel_skor", 50)
    bilesik_skor = round(teknik_skor * 0.6 + temel_skor * 0.4, 1)
    
    prompt = f"""Sen deneyimli bir portföy yöneticisi ve yatırım stratejistisin. Aşağıdaki kapsamlı analiz verilerini kullanarak {sembol} için profesyonel bir yatırım raporu hazırla.

